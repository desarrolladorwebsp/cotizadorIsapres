# Neon PostgreSQL (en Vercel usa la URL con pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Opcional: conexión directa solo para migraciones locales (`npm run db:migrate`)
# En Vercel, si migrate deploy falla en build, usa la URL directa (sin -pooler) en DATABASE_URL
# o configura DIRECT_URL en schema.prisma.
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Autenticación (mínimo 32 caracteres; generar con: openssl rand -base64 48)
AUTH_SECRET=

# URL pública del sitio (links en correos de invitación de usuarios)
# NEXT_PUBLIC_APP_URL=https://cotizador.cotizaloantes.cl
# APP_BASE_URL=https://cotizador.cotizaloantes.cl

# Contraseña inicial para cuentas demo del seed (solo desarrollo)
SEED_ACCOUNT_PASSWORD=Cotizalo2026**

# Cuentas admin (referencia — login: /cotizador/admin/login)
# admin@isaprespremium.cl
# superadmin@isaprespremium.cl
# Usan la contraseña de SEED_ACCOUNT_PASSWORD o la clave temporal enviada por correo.

# API pública para integradores / agentes (mínimo 32 caracteres)
PUBLIC_API_SECRET=
# Opcional: URL base documentada en /api/public/v1/docs (ej. https://cotizador.cotizaloantes.cl/api/public/v1)
# PUBLIC_API_BASE_URL=

# Guía UI cards de planes (sin auth): GET /api/public/v1/ui/plan-card?brand=cotizalo-antes

# Entidad aliada por defecto en / (ej. cotizaloantes)
DEFAULT_PARTNER_ENTITY_SLUG=cotizaloantes

# --- Notificaciones de cotización (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Cotízalo Antes <noreply@cotizaloantes.cl>
COTIZACION_NOTIFY_EMAIL=cotizador@cotizaloantes.cl

# --- PDFs de planes ---
# Local (desarrollo sin Blob): disco en storage/planes-pdf
# PLAN_PDF_STORAGE=local

# Vercel Blob (producción y carga masiva local)
# Crear en: Vercel → Storage → Blob → Connect to project
PLAN_PDF_STORAGE=blob
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=
