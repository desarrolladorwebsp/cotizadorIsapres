# Neon PostgreSQL (en Vercel usa la URL con pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Opcional: conexión directa solo para migraciones locales (`npm run db:migrate`)
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# --- PDFs de planes ---
# Local (desarrollo sin Blob): disco en storage/planes-pdf
# PLAN_PDF_STORAGE=local

# Vercel Blob (producción y carga masiva local)
# Crear en: Vercel → Storage → Blob → Connect to project
PLAN_PDF_STORAGE=blob
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=
